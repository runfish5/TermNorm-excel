# TermNorm Backend API — environment variables
#
# Copy this file to `.env` in the same directory and fill in the values
# you need:
#     cp .env.example .env
#
# Only one LLM provider key is required. Everything else is optional.

# ============================================================
# LLM Provider Keys — pick at least one
# ============================================================

# Groq (recommended — free tier works)
# Get a key at: https://console.groq.com
# GROQ_API_KEY=gsk_your_key_here

# OpenAI
# Get a key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here

# OpenRouter — single key, many upstream models
# Get a key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-your_key_here

# Anthropic (Claude)
# Get a key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# ============================================================
# Web Search (optional — enables the `web_search` pipeline node)
# ============================================================

# Get a key at: https://api.search.brave.com
# BRAVE_SEARCH_API_KEY=your_key_here
# USE_BRAVE_API=true

# ============================================================
# Wire-level bearer auth (optional — for hosted / network deploys)
# ============================================================

# When enabled, every request must carry:
#   Authorization: Bearer <TERMNORM_TOKEN>
# TERMNORM_REQUIRE_AUTH=false
# TERMNORM_TOKEN=

# ============================================================
# Network mode (optional)
# ============================================================

# Bind uvicorn to 0.0.0.0 so the backend is reachable from
# another host on the LAN. Defaults to 127.0.0.1 (local-only).
# UVICORN_HOST=0.0.0.0
